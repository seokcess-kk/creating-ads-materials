# Claude (전략·카피·Vision 분석)
ANTHROPIC_API_KEY=

# Gemini (BP 임베딩 검색 + 이미지 생성 fallback). 임베딩에 쓰이므로 항상 필요.
GEMINI_API_KEY=

# 이미지 생성 provider 선택: openai | gemini (기본 gemini)
# openai로 두려면 OPENAI_API_KEY를 함께 설정해야 한다.
IMAGE_PROVIDER=gemini
OPENAI_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
